check_usage()
{
    readonly argc="$#"

    if (( "$argc" < 1 )) ; then
	>&2 echo "USAGE: $progname BinNumber"
	>&2 echo "Convert binary number to decimal number"
	exit 1
    fi
}

bin2dec()
{
    readonly decimal="$1"
    binary="None"

    echo "bin2dec($decimal)=$binary"
}

main()
{
    readonly progname="$0"

    check_usage "$@"
    bin2dec "$1"
    exit 0
}

main "$@"
